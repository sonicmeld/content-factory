[Unit]
Description=Content Factory FastAPI Backend
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/opt/apps/content-factory/backend
Environment="PATH=/opt/apps/content-factory/backend/venv/bin"
ExecStart=/opt/apps/content-factory/backend/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
